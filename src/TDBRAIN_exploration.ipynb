    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import networkx as nx\n",
    "import mne\n",
    "import matplotlib.image as mpimg\n",
    "\n",
    "# Paramètres\n",
    "subject_id = \"sub-19684666\"\n",
    "freq_band = \"theta\"\n",
    "method = \"coh\"\n",
    "threshold = 0.42\n",
    "filepath = f\"../data/TDBRAIN/connectome/{subject_id}/ses-1/ses-1_{method}_{freq_band}.npy\"\n",
    "connectome = np.load(filepath)\n",
    "\n",
    "# 2. Charger les positions des électrodes (standard_1020)\n",
    "montage = mne.channels.make_standard_montage('standard_1020')\n",
    "ch_names = montage.ch_names[:connectome.shape[0]]\n",
    "pos3d = montage.get_positions()['ch_pos']\n",
    "pos2d_raw = {ch: pos3d[ch][:2] for ch in ch_names if ch in pos3d}\n",
    "\n",
    "# 3. Normaliser les positions pour les caler sur le fond\n",
    "xs, ys = zip(*pos2d_raw.values())\n",
    "x_min, x_max = min(xs), max(xs)\n",
    "y_min, y_max = min(ys), max(ys)\n",
    "\n",
    "pos2d_scaled = {\n",
    "    ch: (\n",
    "        0.2 + 0.6 * (x - x_min) / (x_max - x_min),\n",
    "        0.2 + 0.6 * (y - y_min) / (y_max - y_min)\n",
    "    )\n",
    "    for ch, (x, y) in pos2d_raw.items()\n",
    "}\n",
    "\n",
    "# 4. Construire le graphe\n",
    "G = nx.Graph()\n",
    "for i, ch1 in enumerate(ch_names):\n",
    "    for j, ch2 in enumerate(ch_names):\n",
    "        if i > j:\n",
    "            w = connectome[i, j]\n",
    "            if w > threshold:\n",
    "                G.add_edge(ch1, ch2, weight=w)\n",
    "for ch in ch_names:\n",
    "    G.add_node(ch)\n",
    "\n",
    "# 5. Charger le fond\n",
    "img = mpimg.imread(\"background_brain.jpg\")\n",
    "\n",
    "# 6. Tracer\n",
    "fig, ax = plt.subplots(figsize=(8, 8))\n",
    "ax.imshow(img, extent=[0, 1, 0, 1], aspect='auto', alpha=0.5)\n",
    "\n",
    "edges = G.edges()\n",
    "weights = [G[u][v]['weight'] for u, v in edges]\n",
    "\n",
    "nx.draw_networkx_nodes(G, pos=pos2d_scaled, node_size=80, ax=ax)\n",
    "nx.draw_networkx_edges(\n",
    "    G, pos=pos2d_scaled, edge_color=weights, edge_cmap=plt.cm.Reds, width=1.5, ax=ax\n",
    ")\n",
    "nx.draw_networkx_labels(G, pos=pos2d_scaled, font_size=8, ax=ax)\n",
    "\n",
    "sm = plt.cm.ScalarMappable(cmap=plt.cm.Reds)\n",
    "sm.set_array(weights)\n",
    "fig.colorbar(sm, ax=ax, label=\"Coherence weight\")\n",
    "\n",
    "ax.set_title(f\"Connectome {method.upper()} - {freq_band.capitalize()} Band (seuil > {threshold})\")\n",
    "ax.axis('off')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
